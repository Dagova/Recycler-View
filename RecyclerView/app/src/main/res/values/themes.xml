<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema tablón de madera -->
    <style name="Theme.RecyclerView" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- ActionBar color madera oscura -->
        <item name="colorPrimary">@color/wood_medium</item>
        <item name="colorPrimaryVariant">@color/wood_dark</item>
        <item name="colorOnPrimary">@color/wood_text</item>
        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/wood_light</item>
        <item name="colorSecondaryVariant">@color/wood_dark</item>
        <item name="colorOnSecondary">@color/wood_text</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/wood_dark</item>
    </style>
</resources>